#!/usr/bin/env bash

set -u

find_real_claude() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local path_entry
    local IFS=:
    for path_entry in $PATH; do
        [[ -n "$path_entry" ]] || continue
        [[ "$path_entry" == "$self_dir" ]] && continue
        [[ -x "$path_entry/claude" ]] || continue
        printf '%s\n' "$path_entry/claude"
        return 0
    done
    return 1
}

integration_is_available() {
    [[ "${ZENTTY_CLAUDE_HOOKS_DISABLED:-0}" != "1" ]] || return 1
    [[ -n "${ZENTTY_AGENT_BIN:-}" ]] || return 1
    [[ -x "${ZENTTY_AGENT_BIN}" ]] || return 1
    [[ -n "${ZENTTY_WORKSPACE_ID:-}" ]] || return 1
    [[ -n "${ZENTTY_PANE_ID:-}" ]] || return 1
}

json_escape() {
    local value="${1//\\/\\\\}"
    value="${value//\"/\\\"}"
    printf '%s' "$value"
}

passthrough_subcommand() {
    case "${1:-}" in
        mcp|config|api-key)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

build_hook_args() {
    local hook_command hook_json session_id arg
    local -a args

    hook_command="${ZENTTY_CLAUDE_HOOK_COMMAND:-${ZENTTY_AGENT_BIN:-} claude-hook}"
    hook_command="$(json_escape "$hook_command")"
    hook_json="$(printf '{"hooks":{"SessionStart":[{"matcher":"","hooks":[{"type":"command","command":"%s","timeout":10}]}],"Stop":[{"matcher":"","hooks":[{"type":"command","command":"%s","timeout":10}]}],"SessionEnd":[{"matcher":"","hooks":[{"type":"command","command":"%s","timeout":1}]}],"Notification":[{"matcher":"","hooks":[{"type":"command","command":"%s","timeout":10}]}],"PermissionRequest":[{"matcher":"","hooks":[{"type":"command","command":"%s","timeout":10}]}],"UserPromptSubmit":[{"matcher":"","hooks":[{"type":"command","command":"%s","timeout":10}]}],"PreToolUse":[{"matcher":"","hooks":[{"type":"command","command":"%s","timeout":5,"async":true}]}]}}' "$hook_command" "$hook_command" "$hook_command" "$hook_command" "$hook_command" "$hook_command" "$hook_command")"

    args=("$@")
    for arg in "${args[@]}"; do
        case "$arg" in
            --resume|--resume=*|--session-id|--session-id=*|--continue|-c)
                printf '%s\0' --settings "$hook_json" "${args[@]}"
                return 0
                ;;
        esac
    done

    session_id="$(uuidgen | tr '[:upper:]' '[:lower:]')"
    printf '%s\0' --session-id "$session_id" --settings "$hook_json" "${args[@]}"
}

real_claude="$(find_real_claude)" || {
    echo "Error: claude not found in PATH" >&2
    exit 127
}

if ! integration_is_available || passthrough_subcommand "${1:-}"; then
    unset CLAUDECODE
    exec "$real_claude" "$@"
fi

unset CLAUDECODE
export ZENTTY_CLAUDE_PID=$$

declare -a command_args
while IFS= read -r -d '' argument; do
    command_args+=("$argument")
done < <(build_hook_args "$@")

exec "$real_claude" "${command_args[@]}"
