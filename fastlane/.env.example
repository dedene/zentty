# Optional: hydrate release env vars from 1Password item fields.
# Field labels are normalized into env names, eg `r2_bucket` -> `R2_BUCKET`.
OP_RELEASE_ENV_VAULT=Engineering
OP_RELEASE_ENV_ITEM=Zentty Release Environment

# Legacy fallback if you still keep a .env-style bundle in one secret field.
OP_RELEASE_ENV_REF=

# App Store Connect API Key for notarization
# Generate at https://appstoreconnect.apple.com/access/integrations/api
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_KEY_FILEPATH=

# Match passphrase for encrypting/decrypting certificates
MATCH_PASSWORD=

# GitHub CLI / release notes generation
# Optional if you already have `gh` authenticated locally
GITHUB_TOKEN=

# Cloudflare R2 upload via wrangler
R2_BUCKET=zentty
R2_PUBLIC_BASE_URL=https://releases.zentty.org

# GlitchTip / Sentry DSN for error reporting (optional — builds without it ship with error reporting disabled)
GLITCHTIP_DSN=

# Sparkle signing / feed configuration
SPARKLE_PUBLIC_ED_KEY=
# Optional if you want to supply the private EdDSA key material directly
SPARKLE_PRIVATE_ED_KEY=
# Optional if you keep the private EdDSA key outside the keychain
SPARKLE_PRIVATE_ED_KEY_FILE=
# Optional if you want to override Zentty's default Sparkle keychain account
SPARKLE_KEYCHAIN_ACCOUNT=zentty

# Optional local editor for release notes drafts
EDITOR=

# Set to 0 to disable AI-drafted release notes (falls back to GitHub-generated)
ZENTTY_RELEASE_NOTES_AI=
