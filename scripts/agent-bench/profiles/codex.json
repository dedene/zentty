{
  "name": "codex",
  "command": "codex",
  "real_binary_names": ["codex"],
  "version_args": ["--version"],
  "launch_args_by_scenario": {
    "smoke": [
      "exec",
      "--sandbox",
      "workspace-write",
      "Run this exact shell command: printf ZENTTY_AGENT_BENCH_OK"
    ],
    "approval": [
      "--sandbox",
      "workspace-write",
      "--ask-for-approval",
      "untrusted",
      "Run this exact shell command: printf ZENTTY_AGENT_BENCH_APPROVAL_OK"
    ]
  },
  "expectations": {
    "smoke": {
      "required_events": ["session-start", "prompt-submit", "pre-tool-use", "post-tool-use", "stop"]
    },
    "approval": {
      "required_events": ["session-start", "prompt-submit", "permission-request", "stop"]
    }
  },
  "input_by_scenario": {
    "approval": [
      {
        "match": "trust",
        "text": "1\n"
      },
      {
        "match": "Would you like to run the following command",
        "text": "y\n"
      }
    ]
  },
  "skip_patterns": ["login", "auth", "not authenticated", "api key", "sign in", "no such option"]
}
