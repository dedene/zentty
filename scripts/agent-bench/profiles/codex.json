{
  "name": "codex",
  "command": "codex",
  "real_binary_names": ["codex"],
  "version_args": ["--version"],
  "launch_args_by_scenario": {
    "smoke": [
      "exec",
      "--sandbox",
      "workspace-write",
      "Run this exact shell command: printf ZENTTY_AGENT_BENCH_OK"
    ],
    "session_capture": [
      "exec",
      "--sandbox",
      "workspace-write",
      "Run this exact shell command: printf ZENTTY_AGENT_BENCH_OK"
    ],
    "restart": [
      "exec",
      "--sandbox",
      "workspace-write",
      "Run this exact shell command: printf ZENTTY_AGENT_BENCH_OK"
    ],
    "tui_restart": [
      "--no-alt-screen"
    ],
    "approval": [
      "--sandbox",
      "workspace-write",
      "--ask-for-approval",
      "untrusted",
      "Run this exact shell command: printf ZENTTY_AGENT_BENCH_APPROVAL_OK"
    ],
    "auto_approval": [
      "--ask-for-approval",
      "untrusted",
      "exec",
      "--sandbox",
      "workspace-write",
      "Run this exact shell command: printf ZENTTY_AGENT_BENCH_AUTO_APPROVAL_OK"
    ],
    "question": [
      "Ask me one short random question using the askuserquestion tool. Do not answer it yourself."
    ],
    "question_interrupt": [
      "Ask me one short random question using the askuserquestion tool. Do not answer it yourself."
    ],
    "manual_compact": [
      "--no-alt-screen"
    ],
    "restore_launch": [
      "resume",
      "session-codex"
    ]
  },
  "expectations": {
    "smoke": {
      "required_events": ["session-start", "prompt-submit", "pre-tool-use", "post-tool-use", "stop"]
    },
    "session_capture": {
      "required_events": ["session-start", "prompt-submit", "pre-tool-use", "post-tool-use", "stop"],
      "session_identity": {
        "session_id_pattern": "codex",
        "tracked_pid": true
      }
    },
    "restart": {
      "required_events": [
        "session-start",
        "prompt-submit",
        "pre-tool-use",
        "post-tool-use",
        "stop",
        "session-start",
        "prompt-submit",
        "pre-tool-use",
        "post-tool-use",
        "stop"
      ]
    },
    "tui_restart": {
      "required_events": [],
      "required_terminal_phases": ["idle", "starting", "idle", "starting"]
    },
    "approval": {
      "required_events": ["session-start", "prompt-submit", "permission-request", "post-tool-use", "stop"]
    },
    "auto_approval": {
      "required_events": ["session-start", "prompt-submit", "pre-tool-use", "post-tool-use", "stop"],
      "forbidden_events": ["permission-request"],
      "forbidden_terminal_phases": ["needs-input"]
    },
    "question": {
      "required_events": ["session-start", "prompt-submit"]
    },
    "question_interrupt": {
      "required_events": ["session-start", "prompt-submit"]
    },
    "manual_compact": {
      "required_events": ["pre-compact", "post-compact"]
    },
    "restore_launch": {
      "required_events": [],
      "required_bootstrap_arguments": [["resume", "session-codex"]]
    }
  },
  "input_by_scenario": {
    "approval": [
      {
        "match": "trust",
        "text": "1\n",
        "label": "trust-workspace"
      },
      {
        "match": "Would you like to run the following command",
        "text": "y\n",
        "label": "approve-command"
      }
    ],
    "question": [
      {
        "match": "trust",
        "text": "1\n"
      }
    ],
    "question_interrupt": [
      {
        "match": "trust",
        "text": "1\n",
        "label": "trust-workspace"
      },
      {
        "match": "Action Required",
        "text": "\u0003",
        "label": "ctrl-c"
      }
    ],
    "tui_restart": [
      {
        "match": "trust",
        "text": "1\n",
        "label": "trust-workspace"
      },
      {
        "match": "Context 100% left",
        "text": "/quit\n",
        "label": "quit"
      }
    ],
    "manual_compact": [
      {
        "match": "trust",
        "text": "1\n",
        "label": "trust-workspace"
      },
      {
        "match": "Ready \\| codex-manual_compact",
        "text": "/compact\r",
        "label": "manual-compact"
      }
    ]
  },
  "repeat_by_scenario": {
    "restart": 2,
    "tui_restart": 2
  },
  "skip_patterns": ["login", "auth", "not authenticated", "api key", "sign in", "no such option"]
}
