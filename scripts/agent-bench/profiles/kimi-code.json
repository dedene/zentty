{
  "name": "kimi-code",
  "tool": "kimi",
  "command": "kimi",
  "real_binary_names": ["kimi"],
  "kimi_variant": "modern",
  "version_args": ["--version"],
  "launch_args_by_scenario": {
    "smoke": [
      "-p",
      "Run this exact shell command: printf ZENTTY_AGENT_BENCH_OK"
    ],
    "session_capture": [
      "-p",
      "Run this exact shell command: printf ZENTTY_AGENT_BENCH_OK"
    ],
    "approval": [],
    "restore_launch": [
      "-S",
      "237d8c32-2a27-4850-8da8-3a110f13682c"
    ],
    "resume_roundtrip": [
      "-p",
      "Reply with exactly: ZENTTY_AGENT_BENCH_OK"
    ]
  },
  "expectations": {
    "smoke": {
      "required_events": ["SessionStart", "UserPromptSubmit", "PreToolUse", "PostToolUse", "Stop", "SessionEnd"]
    },
    "session_capture": {
      "required_events": ["SessionStart", "UserPromptSubmit", "PreToolUse", "PostToolUse", "Stop", "SessionEnd"],
      "session_identity": {
        "session_id_pattern": "kimi-code",
        "tracked_pid": true
      }
    },
    "approval": {
      "required_events": ["SessionStart", "UserPromptSubmit", "PreToolUse"]
    },
    "restore_launch": {
      "required_events": [],
      "required_bootstrap_arguments": [["-S", "237d8c32-2a27-4850-8da8-3a110f13682c"]]
    },
    "resume_roundtrip": {
      "resume_roundtrip": true,
      "required_events": []
    }
  },
  "input_by_scenario": {
    "approval": [
      {
        "after": 8,
        "text": "Run this exact shell command: printf ZENTTY_AGENT_BENCH_APPROVAL_OK\r"
      },
      {
        "after": 30,
        "text": "y\r"
      },
      {
        "after": 60,
        "text": "\u0003"
      }
    ]
  },
  "skip_patterns": ["login", "auth", "not authenticated", "api key", "sign in", "LLM not set"]
}
