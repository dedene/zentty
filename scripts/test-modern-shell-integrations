#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

for tool in fish nu; do
  if ! command -v "$tool" >/dev/null 2>&1; then
    echo "Missing required shell: $tool" >&2
    exit 1
  fi
done

if [[ ! -x /usr/bin/expect ]]; then
  echo "Missing required executable: /usr/bin/expect" >&2
  exit 1
fi

git ls-files --error-unmatch \
  ZenttyResources/shell-integration/fish/vendor_conf.d/zentty-shell-integration.fish \
  ZenttyResources/shell-integration/nushell/vendor/autoload/zentty.nu \
  >/dev/null

TEST_RUNNER_SWIFT_BACKTRACE=enable=no xcodebuild test \
  -scheme Zentty \
  -destination 'platform=macOS' \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_fish_shell_integration_enables_wrapper_from_colon_delimited_wrapper_dirs \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_fish_shell_integration_enables_wrapper_once_when_multiple_real_binaries_exist \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_fish_shell_integration_exports_active_wrapper_directories_to_child_processes \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_fish_shell_integration_autoloads_from_xdg_data_dirs_and_reports_typed_command \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_fish_shell_integration_loads_and_executes_runtime_with_bypass \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_fish_pane_context_signal_is_parseable_in_non_git_directory \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_nu_shell_integration_autoloads_from_xdg_data_dirs_in_interactive_repl \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_nu_shell_integration_does_not_enable_non_executable_wrapper_file \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_nu_shell_integration_does_not_enable_wrapper_without_executable_real_binary \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_nu_shell_integration_enables_wrapper_from_colon_delimited_wrapper_dirs \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_nu_shell_integration_enables_wrapper_when_real_binary_is_symlink_to_executable \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_nu_shell_integration_does_not_enable_wrapper_when_real_binary_symlink_target_not_executable \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_nu_shell_integration_loads_when_no_wrappers_enable \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_nu_shell_integration_loads_without_cant_convert_under_real_zentty_env \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_nu_shell_integration_preserves_cd_and_reports_directory_change \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_nu_shell_integration_reports_initial_working_directory_on_first_context \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_nu_shell_integration_tags_codex_pre_execution_command \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_nu_shell_integration_enables_wrapper_through_pre_prompt_hook_closure \
  -only-testing:ZenttyLogicTests/AgentStatusSupportTests/test_shell_integration_does_not_enable_amp_wrapper_when_wrapper_executable_is_missing
