#!/usr/bin/env zsh
set -euo pipefail

display_name="${ZENTTY_TEST_SCREEN_NAME:-ZenttyTests}"
provider="${ZENTTY_TEST_DISPLAY_PROVIDER:-auto}"
display_name_slug="${display_name//[^A-Za-z0-9_.-]/_}"
display_serial="${ZENTTY_TEST_DISPLAY_SERIAL:-zentty-test-display-${display_name_slug}}"
display_lock_file="${TMPDIR:-/tmp}/zentty-test-display-${display_name_slug}.lock"
display_lease_dir="${TMPDIR:-/tmp}/zentty-test-display-${display_name_slug}.leases"
display_lease_token="${$}.${RANDOM}"
active_display_name="$display_name"
display_lock_fd=""
display_lease_registered=0
display_cleanup_ran=0

betterdisplay_command() {
  if [[ -n "${ZENTTY_BETTERDISPLAY_COMMAND:-}" ]]; then
    print -r -- "${ZENTTY_BETTERDISPLAY_COMMAND}"
  elif command -v betterdisplaycli >/dev/null 2>&1; then
    command -v betterdisplaycli
  elif [[ -x /Applications/BetterDisplay.app/Contents/MacOS/BetterDisplay ]]; then
    print -r -- "/Applications/BetterDisplay.app/Contents/MacOS/BetterDisplay"
  else
    return 1
  fi
}

matched_screen_name() {
  if [[ -n "${ZENTTY_TEST_SCREEN_EXISTS_COMMAND:-}" ]]; then
    "$ZENTTY_TEST_SCREEN_EXISTS_COMMAND" "$display_name" >/dev/null 2>&1 || return 1
    print -r -- "$display_name"
    return
  fi

  ZENTTY_SCREEN_LOOKUP_NAME="$display_name" /usr/bin/swift -e '
import AppKit
import Foundation

let screenName = ProcessInfo.processInfo.environment["ZENTTY_SCREEN_LOOKUP_NAME"] ?? ""

func matchesRequestedScreenName(_ localizedName: String, requestedName: String) -> Bool {
    if localizedName == requestedName {
        return true
    }

    let suffixPrefix = requestedName + " ("
    guard localizedName.hasPrefix(suffixPrefix), localizedName.hasSuffix(")") else {
        return false
    }

    let suffixStart = localizedName.index(localizedName.startIndex, offsetBy: suffixPrefix.count)
    let suffix = localizedName[suffixStart..<localizedName.index(before: localizedName.endIndex)]
    return Int(suffix) != nil
}

if let screen = NSScreen.screens.first(where: { matchesRequestedScreenName($0.localizedName, requestedName: screenName) }) {
    print(screen.localizedName)
    exit(0)
}

exit(1)
  ' 2>/dev/null
}

screen_exists() {
  matched_screen_name >/dev/null 2>&1
}

acquire_display_lock() {
  zmodload zsh/system
  touch "$display_lock_file"

  if ! zsystem flock -t 60 -f display_lock_fd "$display_lock_file"; then
    print -u2 "error: timed out waiting for virtual display lock '${display_lock_file}'"
    return 1
  fi
}

release_display_lock() {
  if [[ -n "$display_lock_fd" ]]; then
    zsystem flock -u "$display_lock_fd" >/dev/null 2>&1 || true
    display_lock_fd=""
  fi
}

prune_stale_display_leases() {
  local lease pid

  mkdir -p "$display_lease_dir"
  for lease in "$display_lease_dir"/*(.N); do
    pid="${lease:t}"
    pid="${pid%%.*}"
    if [[ -z "$pid" ]] || ! kill -0 "$pid" >/dev/null 2>&1; then
      command rm -f "$lease"
    fi
  done
}

register_display_lease() {
  mkdir -p "$display_lease_dir"
  print -r -- "$$" > "$display_lease_dir/$display_lease_token"
  display_lease_registered=1
}

release_display_lease() {
  if [[ "$display_lease_registered" != "1" ]]; then
    return
  fi

  command rm -f "$display_lease_dir/$display_lease_token"
  display_lease_registered=0
  prune_stale_display_leases
}

has_active_display_leases() {
  local leases

  leases=("$display_lease_dir"/*(.N))
  (( ${#leases[@]} > 0 ))
}

wait_for_screen() {
  local attempt
  for attempt in {1..30}; do
    if screen_exists; then
      return 0
    fi
    sleep 0.5
  done

  print -u2 "error: virtual display '${display_name}' did not appear in NSScreen.screens"
  return 1
}

resolve_provider() {
  case "$provider" in
    auto)
      if betterdisplay_command >/dev/null 2>&1; then
        print -r -- "betterdisplay"
      elif command -v simpledisplayctl >/dev/null 2>&1; then
        print -r -- "simpledisplay"
      else
        print -u2 "error: no virtual display provider CLI found"
        print -u2 "Install BetterDisplay CLI with: brew install waydabber/betterdisplay/betterdisplaycli"
        print -u2 "Or install SimpleDisplay CLI and set ZENTTY_TEST_DISPLAY_PROVIDER=simpledisplay."
        return 1
      fi
      ;;
    betterdisplay|simpledisplay)
      print -r -- "$provider"
      ;;
    *)
      print -u2 "error: unsupported ZENTTY_TEST_DISPLAY_PROVIDER='${provider}'"
      print -u2 "Supported values: auto, betterdisplay, simpledisplay"
      return 1
      ;;
  esac
}

connect_existing_betterdisplay() {
  local bd="$1"

  "$bd" set -serial="$display_serial" -connected=on >/dev/null 2>&1 && return 0
  "$bd" set -name="$display_name" -virtualScreenSerial="$display_serial" -connected=on >/dev/null 2>&1 && return 0
  return 1
}

ensure_betterdisplay() {
  local bd
  if ! bd="$(betterdisplay_command)"; then
    print -u2 "error: BetterDisplay CLI not found"
    print -u2 "Install it with: brew install waydabber/betterdisplay/betterdisplaycli"
    print -u2 "Fallback supported if BetterDisplay.app is installed at /Applications/BetterDisplay.app."
    return 1
  fi

  if screen_exists; then
    active_display_name="$(matched_screen_name || print -r -- "$display_name")"
    print -r -- "Using existing display '${active_display_name}'. It will be removed by the last test run using it."
    "$bd" set -name="$active_display_name" -virtualScreenSerial="$display_serial" >/dev/null 2>&1 || true
    return 0
  fi

  if connect_existing_betterdisplay "$bd"; then
    wait_for_screen
    active_display_name="$(matched_screen_name || print -r -- "$display_name")"
    print -r -- "Connected existing BetterDisplay virtual display '${active_display_name}'. It will be removed by the last test run using it."
    return 0
  fi

  "$bd" create -devicetype=virtualscreen -virtualscreenname="$display_name" -virtualScreenSerial="$display_serial" -aspectWidth=16 -aspectHeight=10 -virtualScreenHiDPI=on
  "$bd" set -serial="$display_serial" -connected=on
  wait_for_screen
  active_display_name="$(matched_screen_name || print -r -- "$display_name")"
}

cleanup_betterdisplay() {
  local bd
  bd="$(betterdisplay_command)" || return 0
  "$bd" discard -serial="$display_serial" >/dev/null 2>&1 || \
    "$bd" discard -name="$active_display_name" >/dev/null 2>&1 || \
    "$bd" discard -name="$display_name" >/dev/null 2>&1 || true
}

ensure_simpledisplay() {
  if ! command -v simpledisplayctl >/dev/null 2>&1; then
    print -u2 "error: simpledisplayctl not found"
    return 1
  fi

  if screen_exists; then
    active_display_name="$(matched_screen_name || print -r -- "$display_name")"
    print -r -- "Using existing display '${active_display_name}'. It will be removed by the last test run using it."
    return 0
  fi

  simpledisplayctl create --width 2732 --height 2048 --name "$display_name" --hidpi
  wait_for_screen
  active_display_name="$(matched_screen_name || print -r -- "$display_name")"
}

cleanup_simpledisplay() {
  command -v simpledisplayctl >/dev/null 2>&1 || return 0
  simpledisplayctl remove --name "$active_display_name" >/dev/null 2>&1 || \
    simpledisplayctl remove --name "$display_name" >/dev/null 2>&1 || true
}

cleanup_display_if_last_lease() {
  local already_locked=0

  if [[ "$display_cleanup_ran" == "1" ]]; then
    return
  fi
  display_cleanup_ran=1

  if [[ -n "$display_lock_fd" ]]; then
    already_locked=1
  else
    acquire_display_lock
  fi

  release_display_lease

  if ! has_active_display_leases; then
    case "$resolved_provider" in
      betterdisplay) cleanup_betterdisplay ;;
      simpledisplay) cleanup_simpledisplay ;;
    esac
    command rmdir "$display_lease_dir" >/dev/null 2>&1 || true
  fi

  if [[ "$already_locked" == "0" ]]; then
    release_display_lock
  fi
}

resolved_provider="$(resolve_provider)"
trap cleanup_display_if_last_lease EXIT INT TERM

register_display_lease
acquire_display_lock
prune_stale_display_leases
case "$resolved_provider" in
  betterdisplay) ensure_betterdisplay ;;
  simpledisplay) ensure_simpledisplay ;;
esac
release_display_lock

export ZENTTY_TEST_SCREEN_NAME="$display_name"

TEST_RUNNER_SWIFT_BACKTRACE=enable=no \
  TEST_RUNNER_ZENTTY_TEST_SCREEN_NAME="$display_name" \
  xcodebuild test \
  -scheme Zentty \
  -destination 'platform=macOS' \
  "$@"
