{
  "name": "@zentty/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo/ui": "~57.0.7",
    "@expo/vector-icons": "^15.1.1",
    "@stablelib/chacha20poly1305": "2.0.1",
    "@stablelib/ed25519": "2.1.0",
    "@stablelib/hmac": "2.0.1",
    "@stablelib/sha256": "2.0.1",
    "@stablelib/x25519": "2.0.1",
    "@tanstack/react-query": "^5.101.3",
    "@zentty/wire": "workspace:*",
    "expo": "~57.0.7",
    "expo-camera": "~57.0.3",
    "expo-constants": "~57.0.6",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.7",
    "expo-device": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-glass-effect": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-notifications": "~57.0.6",
    "expo-router": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "@types/ws": "8.18.1",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.2",
    "libsodium-wrappers": "0.8.4",
    "tsx": "4.23.1",
    "typescript": "~6.0.3",
    "ws": "8.21.1"
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@zentty/wire$": "<rootDir>/../wire/src/index.ts",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "testMatch": [
      "**/__tests__/**/*.test.[jt]s?(x)",
      "**/?(*.)+(spec|test).[jt]s?(x)"
    ],
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base|standard-navigation|@stablelib))",
      "/node_modules/react-native-reanimated/plugin/",
      "/node_modules/@react-native/babel-preset/"
    ]
  },
  "private": true
}
